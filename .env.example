# Server Configuration
PORT=10000

# MongoDB Configuration
MONGODB_URI=mongodb://root:example@database:27017/RideMate
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/UniRide

# Client URL Configuration
CLIENT_URL=http://localhost:10000

# JWT Configuration
JWT_SECRET=superSecretKey123

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration
GMAIL_USER=your_personal_gmail_address

# Google OAuth & Gmail API Configuration
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_gmail_api_refresh_token
